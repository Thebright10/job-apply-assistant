# Copy this file to ".env" and fill in your own values. Never commit the real .env to GitHub.

# Gmail address the drafts will be saved into
GMAIL_ADDRESS=your_email@gmail.com

# Gmail App Password (NOT your normal password):
# Google Account -> Security -> 2-Step Verification (must be ON) -> App Passwords -> generate one for "Mail"
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Optional, for India-specific listings via Adzuna. Free keys: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
